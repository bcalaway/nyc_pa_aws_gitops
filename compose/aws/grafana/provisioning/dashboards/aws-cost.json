{
  "title": "AWS Cost",
  "uid": "aws-cost",
  "tags": ["home-platform"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1h",
  "time": { "from": "now-90d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Month to Date",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "aws_cost_month_to_date_usd", "legendFormat": "MTD", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] }
    },
    {
      "id": 2,
      "title": "Forecasted Month Total",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "aws_cost_forecast_month_usd", "legendFormat": "Forecast", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] }
    },
    {
      "id": 3,
      "title": "Yesterday",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "aws_cost_yesterday_usd", "legendFormat": "Yesterday", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] }
    },
    {
      "id": 4,
      "title": "Month-to-Date Trend",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "aws_cost_month_to_date_usd", "legendFormat": "MTD actual", "refId": "A" },
        { "expr": "aws_cost_forecast_month_usd", "legendFormat": "Forecasted total", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] }
    },
    {
      "id": 5,
      "title": "Daily Cost by Service",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "aws_cost_by_service_usd", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } }
    }
  ]
}

{
  "title": "AWS Hub",
  "uid": "aws-hub",
  "tags": ["home-platform"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Scrape Targets Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "up", "legendFormat": "{{job}} ({{instance}})", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",instance=\"aws-hub\"}[5m])) * 100)", "legendFormat": "CPU %", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] }
    },
    {
      "id": 3,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "(1 - (node_memory_MemAvailable_bytes{instance=\"aws-hub\"} / node_memory_MemTotal_bytes{instance=\"aws-hub\"})) * 100", "legendFormat": "Memory %", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] }
    },
    {
      "id": 4,
      "title": "Disk Usage (root)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "100 - ((node_filesystem_avail_bytes{instance=\"aws-hub\",mountpoint=\"/\"} / node_filesystem_size_bytes{instance=\"aws-hub\",mountpoint=\"/\"}) * 100)", "legendFormat": "Disk %", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] }
    },
    {
      "id": 5,
      "title": "Load Average",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "node_load1{instance=\"aws-hub\"}", "legendFormat": "1m", "refId": "A" },
        { "expr": "node_load5{instance=\"aws-hub\"}", "legendFormat": "5m", "refId": "B" },
        { "expr": "node_load15{instance=\"aws-hub\"}", "legendFormat": "15m", "refId": "C" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 6,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{instance=\"aws-hub\",device!=\"lo\"}[5m])", "legendFormat": "RX {{device}}", "refId": "A" },
        { "expr": "rate(node_network_transmit_bytes_total{instance=\"aws-hub\",device!=\"lo\"}[5m])", "legendFormat": "TX {{device}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }
    }
  ]
}

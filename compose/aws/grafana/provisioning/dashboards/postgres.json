{
  "title": "Postgres",
  "uid": "postgres",
  "tags": ["home-platform"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "pg_up", "legendFormat": "postgres", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "pg_stat_database_numbackends{datname!~\"template0|template1\"}", "legendFormat": "{{datname}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 3,
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_blks_hit{datname!~\"template0|template1\"}[5m])) / (sum(rate(pg_stat_database_blks_hit{datname!~\"template0|template1\"}[5m])) + sum(rate(pg_stat_database_blks_read{datname!~\"template0|template1\"}[5m]))) * 100",
          "legendFormat": "cache hit %",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] }
    },
    {
      "id": 4,
      "title": "Database Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "pg_database_size_bytes{datname!~\"template0|template1\"}", "legendFormat": "{{datname}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "decbytes" }, "overrides": [] }
    },
    {
      "id": 5,
      "title": "Transactions / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(pg_stat_database_xact_commit{datname!~\"template0|template1\"}[5m])", "legendFormat": "{{datname}} commits", "refId": "A" },
        { "expr": "rate(pg_stat_database_xact_rollback{datname!~\"template0|template1\"}[5m])", "legendFormat": "{{datname}} rollbacks", "refId": "B" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 6,
      "title": "Deadlocks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(pg_stat_database_deadlocks{datname!~\"template0|template1\"}[5m])", "legendFormat": "{{datname}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ]
}

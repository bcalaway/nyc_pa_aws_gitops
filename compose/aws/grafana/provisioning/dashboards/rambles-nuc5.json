{
  "title": "Rambles NUC (nuc5)",
  "uid": "rambles-nuc5",
  "tags": ["home-platform"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Scrape Targets Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "up{instance=\"nuc5\"}", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",instance=\"nuc5\"}[5m])) * 100)", "legendFormat": "CPU %", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] }
    },
    {
      "id": 3,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "(1 - (node_memory_MemAvailable_bytes{instance=\"nuc5\"} / node_memory_MemTotal_bytes{instance=\"nuc5\"})) * 100", "legendFormat": "Memory %", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] }
    },
    {
      "id": 4,
      "title": "Disk Usage (root)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "100 - ((node_filesystem_avail_bytes{instance=\"nuc5\",mountpoint=\"/\"} / node_filesystem_size_bytes{instance=\"nuc5\",mountpoint=\"/\"}) * 100)", "legendFormat": "Disk %", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] }
    },
    {
      "id": 5,
      "title": "Load Average",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "node_load1{instance=\"nuc5\"}", "legendFormat": "1m", "refId": "A" },
        { "expr": "node_load5{instance=\"nuc5\"}", "legendFormat": "5m", "refId": "B" },
        { "expr": "node_load15{instance=\"nuc5\"}", "legendFormat": "15m", "refId": "C" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 6,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{instance=\"nuc5\",device!=\"lo\"}[5m])", "legendFormat": "RX {{device}}", "refId": "A" },
        { "expr": "rate(node_network_transmit_bytes_total{instance=\"nuc5\",device!=\"lo\"}[5m])", "legendFormat": "TX {{device}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }
    },
    {
      "id": 7,
      "title": "WAN Reachability",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "probe_success{job=\"blackbox-icmp\",site=\"rambles\"}", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "WAN Latency (ICMP)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "probe_duration_seconds{job=\"blackbox-icmp\",site=\"rambles\"}", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 9,
      "title": "Speedtest Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "speedtest_download_bits_per_second{instance=\"nuc5\"}", "legendFormat": "Download", "refId": "A" },
        { "expr": "speedtest_upload_bits_per_second{instance=\"nuc5\"}", "legendFormat": "Upload", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps" }, "overrides": [] }
    },
    {
      "id": 10,
      "title": "Speedtest Ping / Jitter",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "speedtest_ping_latency_milliseconds{instance=\"nuc5\"}", "legendFormat": "Ping", "refId": "A" },
        { "expr": "speedtest_jitter_latency_milliseconds{instance=\"nuc5\"}", "legendFormat": "Jitter", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    }
  ]
}

{
  "title": "Syslog Explorer",
  "uid": "syslog-explorer",
  "tags": ["home-platform"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "device",
        "type": "query",
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "query": "label_values({job=~\"network-syslog|systemd-journal\"}, device)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "search",
        "type": "textbox",
        "label": "Search (regex, case-insensitive)",
        "query": "",
        "current": { "text": "", "value": "" }
      },
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "query": "label_values({job=\"systemd-journal\"}, container)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Log Lines (selected range)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        { "expr": "sum(count_over_time({job=~\"network-syslog|systemd-journal\", device=~\"$device\"} |~ \"(?i)$search\" [$__range]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 2,
      "title": "Log Volume by Device",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        { "expr": "sum by (device) (count_over_time({job=~\"network-syslog|systemd-journal\", device=~\"$device\"} |~ \"(?i)$search\" [$__interval]))", "legendFormat": "{{device}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 3,
      "title": "Logs",
      "type": "logs",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        { "expr": "{job=~\"network-syslog|systemd-journal\", device=~\"$device\"} |~ \"(?i)$search\"", "refId": "A" }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 4,
      "title": "Container Logs (Docker stdout/stderr, via journald)",
      "type": "logs",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        { "expr": "{job=\"systemd-journal\", container=~\"$container\"} |~ \"(?i)$search\"", "refId": "A" }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}
